{
  "expo": {
    "name": "TalentSwipe",
    "slug": "talentswipe",
    "version": "1.0.0",
    "scheme": "talentswipe",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      "expo-image-picker"
    ],
    "android": {
      "package": "com.talentswipe.app",
      "jsEngine": "hermes",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "jsEngine": "hermes",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fa6130f5-5f7b-4394-8c02-d33a9e531d2b"
      }
    }
  }
}
